# ─── Supabase (클라이언트용 — EXPO_PUBLIC_ 사용 가능) ────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Kakao (클라이언트용 — 공개 식별자) ──────────────────────────────────────
EXPO_PUBLIC_KAKAO_REST_API_KEY=your-kakao-rest-api-key
EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=your-kakao-native-app-key
EXPO_PUBLIC_KAKAO_REDIRECT_URI=https://your-project-id.supabase.co/auth/v1/callback

# ─── 앱 스킴 ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_SCHEME=ott-info

# ─── 아래 값들은 절대 이 파일에 실제 값을 넣지 말 것 ──────────────────────────
# Edge Function secret으로만 관리:
#   supabase secrets set TMDB_API_KEY=...
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...
#   supabase secrets set ADMIN_SECRET=...
